generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Komentar {
  id       String   @default(cuid())
  solusi   Solusi   @relation(fields: [idsolusi], references: [id])
  idsolusi String
  komen    String   @db.Text
  user     Akun     @relation(fields: [iduser], references: [id])
  iduser   String
  bikin    DateTime @default(now())
  upvote   String   @default("[]") @db.Text
  downvote String   @default("[]") @db.Text

  @@id([id, idsolusi, iduser])
  @@unique([id])
  @@map("komentar")
}

model Soal {
  id            String   @id @default(cuid())
  // idsoal        String @db.VarChar(15)
  pembuat       Akun     @relation(fields: [idpembuat], references: [id])
  idpembuat     String
  namasoal      String   @db.TinyText
  level         Int      @db.TinyInt
  tags          String   @default("[]") @db.TinyText
  soal          String   @db.MediumText
  public        Boolean  @default(false)
  suka          String   @default("[]") @db.Text
  solusi        Solusi[]
  listjawaban   String   @db.Text
  contohjawaban String   @db.Text
  bikin         DateTime @default(now())

  @@map("soal")
}

model Solusi {
  id         String     @default(cuid())
  // idsolusi String     @db.VarChar(15)
  soal       Soal       @relation(fields: [idsoal], references: [id])
  idsoal     String
  user       Akun       @relation(fields: [idusername], references: [id])
  idusername String
  pintar     String     @default("[]") @db.Text
  komentar   Komentar[]
  kode       String     @db.MediumText
  kapan      DateTime   @default(now())
  bahasa     String     @db.VarChar(15)

  @@id([id, idsoal, idusername])
  @@unique([id])
  @@map("solusi")
}

model Akun {
  id              String      @id @default(cuid())
  // userid      String  @db.VarChar(20)
  username        String      @db.VarChar(20)
  email           String      @db.VarChar(30)
  password        String      @db.VarChar(60)
  soalselesai     Solusi[]
  buatsoal        Soal[]
  komentar        Komentar[]
  akungithub      AkunGithub?
  githubstate     String?     @db.VarChar(30)
  gambarurl       String      @default("/gambar/profile.png")
  sudahVerifikasi Boolean     @default(false)
  nama            String?     @db.VarChar(35)
  bio             String?     @db.VarChar(65)
  tinggal         String?     @db.VarChar(30)
  website         String?     @db.TinyText
  perbaruiToken   String?     @db.Text
  bikin           DateTime    @default(now())
  terminate       Boolean     @default(false)

  @@map("akun")
}

model AkunGithub {
  id       Int     @id @default(autoincrement())
  email    String
  username String
  gambar   String  @default("")
  user     Akun?   @relation(fields: [iduser], references: [id])
  iduser   String? @unique

  @@unique([email, username])
  @@map("akungithub")
}
